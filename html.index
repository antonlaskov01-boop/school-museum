            { id: 39, name: "Истребитель Fw 190", country: "german", type: "aircraft", class: "Истребитель", maxAltitude: "11400 м", maxSpeed: "685 км/ч", range: "800 км", landingGear: "Убирающееся", crew: "1 человек", armament: "4×20-мм пушки MG 151/20, 2×13-мм пулемёта MG 131", designer: "Курт Танк", period: "1941-1945 гг.", pilots: "Отто Киттель (267 побед), Вальтер Новотны (258 побед)", culture: "Фильмы о воздушных боях", image: "https://upload.wikimedia.org/wikipedia/commons/7/79/Fw_190A-3_JG_2_in_Britain_1942.jpg", description: "Один из лучших немецких истребителей Второй мировой войны.", year: "1943-1945" },
            { id: 40, name: "Танк Tiger II", country: "german", type: "tank", class: "Тяжёлый танк", maxAltitude: "-", maxSpeed: "38 км/ч", range: "170 км", landingGear: "Гусеничный", crew: "5 человек", armament: "88-мм пушка KwK 43, 2×7.92-мм пулемёта MG 34", designer: "Henschel & Son", period: "1944-1945 гг.", pilots: "Экипажи тяжёлых танковых батальонов", culture: "Фильмы о завершающем этапе войны", image: "https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/Bovington_Tiger_II_grey_bg.jpg/1280px-Bovington_Tiger_II_grey_bg.jpg", description: "Немецкий тяжёлый танк, также известный как 'Королевский тигр'.", year: "1943-1945" },
            { id: 41, name: "Танк Panther", country: "german", type: "tank", class: "Средний танк", maxAltitude: "-", maxSpeed: "46 км/ч", range: "250 км", landingGear: "Гусеничный", crew: "5 человек", armament: "75-мм пушка KwK 42, 2×7.92-мм пулемёта MG 34", designer: "MAN AG", period: "1943-1945 гг.", pilots: "Экипажи танковых дивизий", culture: "Фильмы о Курской битве", image: "https://upload.wikimedia.org/wikipedia/commons/4/4e/PanzerV_Ausf.G_1_sk.jpg", description: "Немецкий средний танк, считавшийся одним из лучших танков войны.", year: "1943-1945" },
            { id: 42, name: "Танк Т-35", country: "soviet", type: "tank", class: "Тяжёлый танк", maxAltitude: "-", maxSpeed: "30 км/ч", range: "150 км", landingGear: "Гусеничный", crew: "11 человек", armament: "76-мм пушка, 2×45-мм пушки, 5×7.62-мм пулемёта", designer: "Н.В. Барыков", period: "1933-1939 гг.", pilots: "Экипажи тяжёлых танковых полков", culture: "Документальные фильмы", image: "https://upload.wikimedia.org/wikipedia/commons/2/2d/T35_7.jpg", description: "Советский пятибашенный тяжёлый танк.", year: "1941-1942" },
            { id: 43, name: "Штурмовик Су-25", country: "soviet", type: "aircraft", class: "Штурмовик", maxAltitude: "7000 м", maxSpeed: "950 км/ч", range: "750 км", landingGear: "Убирающееся", crew: "1 человек", armament: "30-мм пушка ГШ-30-2, до 4400 кг боевой нагрузки", designer: "П.О. Сухой", period: "1981-н.в.", pilots: "Герои России", culture: "Фильмы о современных конфликтах", image: "https://upload.wikimedia.org/wikipedia/commons/7/7b/Sukhoi_Su-25SM_%C2%ABRoman_Filipov%C2%BB_05.jpg", description: "Советский и российский бронированный штурмовик, 'летающий танк'.", year: "modern" },
            { id: 44, name: "Танк Т-80БВ", country: "soviet", type: "tank", class: "Основной боевой танк", maxAltitude: "-", maxSpeed: "70 км/ч", range: "500 км", landingGear: "Гусеничный", crew: "3 человека", armament: "125-мм гладкоствольная пушка 2А46М-1, 12.7-мм пулемёт НСВТ, 7.62-мм пулемёт ПКТ", designer: "Кировский завод", period: "1985-н.в.", pilots: "Российские танкисты", culture: "Современные военные фильмы", image: "https://upload.wikimedia.org/wikipedia/commons/a/a8/Russian_T-80BV.jpg", description: "Советский и российский основной боевой танк с газотурбинным двигателем.", year: "modern" },
            { id: 45, name: "РСЗО БМ-21 'Град'", country: "soviet", type: "artillery", class: "Реактивная система залпового огня", maxAltitude: "-", maxSpeed: "75 км/ч", range: "20500 м", landingGear: "Колёсный", crew: "6 человек", armament: "40×122-мм реактивных снарядов", designer: "НИИ-147", period: "1963-н.в.", pilots: "Расчеты реактивной артиллерии", culture: "Современные документальные фильмы", image: "https://upload.wikimedia.org/wikipedia/commons/7/7d/ParkPatriot2015part5-37.jpg", description: "Советская и российская РСЗО, одна из самых массовых в мире.", year: "modern" },
            { id: 46, name: "Танк Т-72Б3", country: "soviet", type: "tank", class: "Основной боевой танк", maxAltitude: "-", maxSpeed: "60 км/ч", range: "500 км", landingGear: "Гусеничный", crew: "3 человека", armament: "125-мм гладкоствольная пушка 2А46М-5, 12.7-мм пулемёт НСВТ, 7.62-мм пулемёт ПКТ", designer: "Уралвагонзавод", period: "2012-н.в.", pilots: "Российские танкисты", culture: "Современные военные фильмы", image: "https://upload.wikimedia.org/wikipedia/commons/5/56/Alabino05042017-40.jpg", description: "Современная российская модернизация танка Т-72.", year: "modern" },
            { id: 47, name: "Танк КВ-1", country: "soviet", type: "tank", class: "Тяжёлый танк", maxAltitude: "-", maxSpeed: "35 км/ч", range: "250 км", landingGear: "Гусеничный", crew: "5 человек", armament: "76-мм пушка Ф-32, 3×7.62-мм пулемёта ДТ", designer: "Ж.Я. Котин", period: "1940-1942 гг.", pilots: "З.Г. Колобанов", culture: "Фильмы: 'Белый тигр'", image: "https://upload.wikimedia.org/wikipedia/commons/3/38/KV-1.JPG", description: "Советский тяжёлый танк начала войны. Отличался мощной бронёй.", year: "1941-1942" },
            { id: 48, name: "Танк ИС-2", country: "soviet", type: "tank", class: "Тяжёлый танк", maxAltitude: "-", maxSpeed: "37 км/ч", range: "240 км", landingGear: "Гусеничный", crew: "4 человека", armament: "122-мм пушка Д-25Т, 3×7.62-мм пулемёта ДТ, 1×12.7-мм ДШК", designer: "Ж.Я. Котин, Н.Л. Духов", period: "1943-1945 гг.", pilots: "Герои битвы за Берлин", culture: "Фильмы о завершающем этапе войны", image: "https://upload.wikimedia.org/wikipedia/commons/1/13/TankBiathlon2016opening-10.jpg", description: "Мощный советский тяжёлый танк завершающего периода войны.", year: "1943-1945" },
            { id: 49, name: "Бронеавтомобиль БА-10", country: "soviet", type: "car", class: "Средний бронеавтомобиль", maxAltitude: "-", maxSpeed: "53 км/ч", range: "300 км", landingGear: "Колёсный", crew: "4 человека", armament: "45-мм пушка 20-К, 2×7.62-мм пулемёта ДТ", designer: "И.В. Гавалов", period: "1938-1941 гг.", pilots: "Экипажи разведывательных подразделений", culture: "Документальные фильмы", image: "https://upload.wikimedia.org/wikipedia/commons/3/33/%D0%91%D1%80%D0%BE%D0%BD%D0%B5%D0%B0%D0%B2%D1%82%D0%BE%D0%BC%D0%BE%D0%B1%D0%B8%D0%BB%D1%8C_%D0%91%D0%90-10_%D0%B2_%D0%9C%D1%83%D0%B7%D0%B5%D0%B5_%D0%BE%D1%82%D0%B5%D1%87%D0%B5%D1%81%D1%82%D0%B2%D0%B5%D0%BD%D0%BD%D0%BE%D0%B9_%D0%B2%D0%BE%D0%B5%D0%BD%D0%BD%D0%BE%D0%B9_%D0%B8%D1%81%D1%82%D0%BE%D1%80%D0%B8%D0%B8.jpg", description: "Советский средний бронеавтомобиль.", year: "1941-1942" },
            { id: 50, name: "Грузовик ГАЗ-АА 'Полуторка'", country: "soviet", type: "truck", class: "Грузовой автомобиль", maxAltitude: "-", maxSpeed: "70 км/ч", range: "215 км", landingGear: "Колёсный", crew: "2 человека", armament: "Невооружённый", designer: "ГАЗ", period: "1932-1950 гг.", pilots: "Советские водители", culture: "Фильмы о войне", image: "https://upload.wikimedia.org/wikipedia/commons/4/41/%D0%93%D0%90%D0%97-%D0%90%D0%90_%28%22%D0%9F%D0%BE%D0%BB%D1%83%D1%82%D0%BE%D1%80%D0%BA%D0%B0%22%29.jpg", description: "Советский грузовик грузоподъёмностью 1.5 тонны.", year: "1941-1942" },
        ];  

        // ===================== ТЕКСТЫ ДЛЯ АУДИОГИДОВ =====================
        const exhibitAudioTexts = {};
        exhibitsData.forEach(ex => { exhibitAudioTexts[ex.id] = `${ex.name}. ${ex.description}. ${ex.designer}, ${ex.period}. Скорость ${ex.maxSpeed}, вооружение: ${ex.armament}.`; });

        // ===================== TTS МЕНЕДЖЕР =====================
        class TTSManager {
            constructor() {
                this.isSupported = 'speechSynthesis' in window;
                this.currentUtterance = null;
                this.isSpeaking = false;
                this.currentProgress = 0;
                this.progressInterval = null;
                this.totalDuration = 30;
                this.init();
            }
            init() { if (this.isSupported) speechSynthesis.getVoices(); }
            speak(text, options = {}) {
                if (!this.isSupported) return false;
                this.stop();
                this.currentUtterance = new SpeechSynthesisUtterance(text);
                this.currentUtterance.lang = options.lang || 'ru-RU';
                this.currentUtterance.rate = options.rate || 1.0;
                this.currentUtterance.pitch = options.pitch || 1.0;
                this.currentUtterance.volume = options.volume || 1.0;
                const voices = speechSynthesis.getVoices();
                const russianVoice = voices.find(voice => voice.lang.startsWith('ru') || voice.name.includes('Russian'));
                if (russianVoice) this.currentUtterance.voice = russianVoice;
                this.currentUtterance.onstart = () => { this.isSpeaking = true; this.startProgressTimer(); if (options.onStart) options.onStart(); document.getElementById('ttsIndicator')?.classList.add('show'); };
                this.currentUtterance.onend = () => { this.isSpeaking = false; this.stopProgressTimer(); this.currentProgress = 0; if (options.onEnd) options.onEnd(); document.getElementById('ttsIndicator')?.classList.remove('show'); };
                this.currentUtterance.onerror = () => { this.isSpeaking = false; this.stopProgressTimer(); if (options.onError) options.onError(); document.getElementById('ttsIndicator')?.classList.remove('show'); };
                speechSynthesis.speak(this.currentUtterance);
                return true;
            }
            pause() { if (this.isSpeaking) speechSynthesis.pause(); this.stopProgressTimer(); }
            resume() { if (this.isSpeaking && speechSynthesis.paused) speechSynthesis.resume(); this.startProgressTimer(); }
            stop() { speechSynthesis.cancel(); this.isSpeaking = false; this.stopProgressTimer(); this.currentProgress = 0; document.getElementById('ttsIndicator')?.classList.remove('show'); }
            startProgressTimer() { this.stopProgressTimer(); this.progressInterval = setInterval(() => { this.currentProgress += 100 / (this.totalDuration * 10); if (this.currentProgress >= 100) this.stopProgressTimer(); }, 100); }
            stopProgressTimer() { if (this.progressInterval) { clearInterval(this.progressInterval); this.progressInterval = null; } }
            getProgress() { return Math.min(this.currentProgress, 100); }
            isTTSAvailable() { return this.isSupported; }
        }
        const ttsManager = new TTSManager();

        // ===================== DOM ЭЛЕМЕНТЫ =====================
        const gallery = document.getElementById('exhibitsContainer');
        const modal = document.getElementById('exhibitModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalImage = document.getElementById('modalImage');
        const modalSpecs = document.getElementById('modalSpecs');
        const modalCrew = document.getElementById('modalCrew');
        const modalCulture = document.getElementById('modalCulture');
        const closeModal = document.getElementById('closeModal');
        const modalShareLink = document.getElementById('modalShareLink');

        let currentExhibitAudioPlayer = null;
        let isExhibitAudioPlaying = false;

        function getCountryText(country) { switch(country) { case 'soviet': return 'СССР'; case 'german': return 'Германия'; case 'american': return 'США'; case 'british': return 'Великобритания'; case 'japanese': return 'Япония'; default: return country; } }
        function getTypeText(type) { switch(type) { case 'aircraft': return 'Самолёт'; case 'tank': return 'Танк'; case 'bomber': return 'Бомбардировщик'; case 'truck': return 'Грузовик'; case 'car': return 'Автомобиль'; case 'artillery': return 'Артиллерия'; default: return type; } }
        function createExhibitLink(id) { return `${window.location.origin}${window.location.pathname}?id=${id}`; }

        function generateExhibitQrCode(cardElement, exhibitId) {
            if (typeof qrcode !== 'function') return;
            const qrContainer = document.createElement('div'); qrContainer.className = 'exhibit-qr-container'; qrContainer.title = 'QR-код экспоната';
            const canvas = document.createElement('canvas'); canvas.className = 'exhibit-qr-canvas'; canvas.width = 80; canvas.height = 80;
            qrContainer.appendChild(canvas); cardElement.appendChild(qrContainer);
            const url = createExhibitLink(exhibitId);
            try {
                const qr = qrcode(0, 'M'); qr.addData(url); qr.make();
                const size = qr.getModuleCount(); const ctx = canvas.getContext('2d'); const cellSize = canvas.width / size;
                for (let row = 0; row < size; row++) for (let col = 0; col < size; col++) { ctx.fillStyle = qr.isDark(row, col) ? '#000000' : '#ffffff'; ctx.fillRect(col * cellSize, row * cellSize, cellSize, cellSize); }
            } catch(e) { console.warn(e); }
        }

        // Фильтрация по странам и годам
        let currentCountryFilter = 'all';
        let currentYearFilter = 'all';

        function applyFilters() {
            const exhibits = document.querySelectorAll('.exhibit');
            exhibits.forEach(exhibit => {
                const country = exhibit.getAttribute('data-category');
                const year = exhibit.getAttribute('data-year');
                const matchCountry = (currentCountryFilter === 'all' || country === currentCountryFilter);
                const matchYear = (currentYearFilter === 'all' || year === currentYearFilter);
                if (matchCountry && matchYear) exhibit.classList.add('show');
                else exhibit.classList.remove('show');
            });
        }

        function createGallery() {
            gallery.innerHTML = '';
            exhibitsData.forEach(exhibit => {
                const exhibitElement = document.createElement('div');
                exhibitElement.className = `exhibit show`;
                exhibitElement.setAttribute('data-category', exhibit.country);
                exhibitElement.setAttribute('data-year', exhibit.year);
                exhibitElement.setAttribute('data-id', exhibit.id);

                let flagClass = '', flagText = '';
                switch (exhibit.country) {
                    case 'soviet': flagClass = 'soviet'; flagText = 'СССР'; break;
                    case 'german': flagClass = 'german'; flagText = 'ГЕР'; break;
                    case 'american': flagClass = 'american'; flagText = 'США'; break;
                    case 'british': flagClass = 'british'; flagText = 'ВБ'; break;
                    case 'japanese': flagClass = 'japanese'; flagText = 'ЯП'; break;
                }
                let typeClass = exhibit.type, typeText = getTypeText(exhibit.type);
                let tagTypeClass = '';
                if (exhibit.type === 'aircraft' || exhibit.type === 'bomber') tagTypeClass = 'fighter';
                else if (exhibit.type === 'tank') tagTypeClass = 'tank';
                else if (exhibit.type === 'artillery') tagTypeClass = 'artillery';
                else if (exhibit.type === 'truck' || exhibit.type === 'car') tagTypeClass = 'transport';
                else tagTypeClass = 'transport';

                const hasAudio = exhibitAudioTexts[exhibit.id];
                const audioIndicator = hasAudio ? `<div class="exhibit-audio-indicator" title="Есть аудиогид"><i class="fas fa-headphones"></i></div>` : '';

                exhibitElement.innerHTML = `
                    <a href="${createExhibitLink(exhibit.id)}" class="exhibit-link" title="Отдельная ссылка"><i class="fas fa-link"></i></a>
                    <div class="exhibit-img">
                        <img src="${exhibit.image}" alt="${exhibit.name}" loading="lazy">
                        ${audioIndicator}
                        <div class="country-flag ${flagClass}">${flagText}</div>
                    </div>
                    <div class="exhibit-info">
                        <h3>${exhibit.name}</h3>
                        <div class="exhibit-specs">
                            <div class="spec-item"><span class="spec-label">Класс:</span><span class="spec-value">${exhibit.class}</span></div>
                            <div class="spec-item"><span class="spec-label">Скорость:</span><span class="spec-value">${exhibit.maxSpeed}</span></div>
                            <div class="spec-item"><span class="spec-label">Дальность:</span><span class="spec-value">${exhibit.range}</span></div>
                            <div class="spec-item"><span class="spec-label">Экипаж:</span><span class="spec-value">${exhibit.crew}</span></div>
                        </div>
                        <div class="exhibit-tags"><span class="tag ${flagClass}">${flagText}</span><span class="tag ${tagTypeClass}">${typeText}</span><span class="tag">${exhibit.crew}</span></div>
                    </div>
                `;
                exhibitElement.addEventListener('click', (e) => { if (!e.target.closest('.exhibit-link')) openModal(exhibit); });
                gallery.appendChild(exhibitElement);
                generateExhibitQrCode(exhibitElement, exhibit.id);
            });
        }

        // ===================== МОДАЛЬНОЕ ОКНО =====================
        function createExhibitAudioPlayer(exhibitId, exhibitName) {
            const hasAudio = exhibitAudioTexts[exhibitId];
            return `<div class="exhibit-audio-player" data-exhibit-id="${exhibitId}">
                <div class="audio-player-header"><h4><i class="fas fa-headphones"></i> Аудиогид: ${exhibitName}</h4></div>
                ${hasAudio ? `<div class="exhibit-audio-controls"><button class="exhibit-audio-btn play-stop-btn"><i class="fas fa-play"></i></button><div class="exhibit-audio-progress"><div class="exhibit-audio-progress-bar"><div class="exhibit-audio-progress-fill"></div></div><div class="exhibit-audio-time"><span class="current-time">0:00</span> / <span class="total-time">0:30</span></div></div></div><p class="audio-note-small"><i class="fas fa-info-circle"></i> Краткое аудиоописание техники</p>` : `<p class="audio-note-small"><i class="fas fa-info-circle"></i> Аудиоописание временно недоступно</p>`}</div>`;
        }
        function initExhibitAudioPlayer(exhibitId) {
            if (isExhibitAudioPlaying) { ttsManager.stop(); isExhibitAudioPlaying = false; }
            if (currentExhibitAudioPlayer) { currentExhibitAudioPlayer.remove(); currentExhibitAudioPlayer = null; }
            const player = document.querySelector(`.exhibit-audio-player[data-exhibit-id="${exhibitId}"]`);
            if (!player) return;
            currentExhibitAudioPlayer = player;
            const playStopBtn = player.querySelector('.play-stop-btn');
            const progressFill = player.querySelector('.exhibit-audio-progress-fill');
            const progressBar = player.querySelector('.exhibit-audio-progress-bar');
            const currentTimeEl = player.querySelector('.current-time');
            const totalTimeEl = player.querySelector('.total-time');
            if (!playStopBtn || !exhibitAudioTexts[exhibitId]) return;
            let progressInterval = null, currentTime = 0;
            const totalTime = 30;
            function formatTime(seconds) { const mins = Math.floor(seconds / 60); const secs = Math.floor(seconds % 60); return `${mins}:${secs < 10 ? '0' : ''}${secs}`; }
            function updateProgress() { if (isExhibitAudioPlaying) { currentTime += 0.1; const progress = (currentTime / totalTime) * 100; if (progressFill) progressFill.style.width = `${Math.min(progress, 100)}%`; if (currentTimeEl) currentTimeEl.textContent = formatTime(currentTime); if (currentTime >= totalTime) stopAudio(); } }
            function stopAudio() { ttsManager.stop(); isExhibitAudioPlaying = false; currentTime = 0; if (progressInterval) clearInterval(progressInterval); if (playStopBtn) playStopBtn.innerHTML = '<i class="fas fa-play"></i>'; if (progressFill) progressFill.style.width = '0%'; if (currentTimeEl) currentTimeEl.textContent = '0:00'; }
            playStopBtn.addEventListener('click', () => {
                if (!isExhibitAudioPlaying) {
                    const text = exhibitAudioTexts[exhibitId];
                    const success = ttsManager.speak(text, { rate: 1.5, onStart: () => { isExhibitAudioPlaying = true; playStopBtn.innerHTML = '<i class="fas fa-stop"></i>'; progressInterval = setInterval(updateProgress, 100); }, onEnd: stopAudio, onError: () => { alert('Не удалось воспроизвести аудио.'); stopAudio(); } });
                    if (!success) alert('Ваш браузер не поддерживает синтез речи. Текстовое описание: ' + text);
                } else stopAudio();
            });
            if (progressBar) progressBar.addEventListener('click', (e) => { const rect = progressBar.getBoundingClientRect(); const pos = (e.clientX - rect.left) / rect.width; currentTime = pos * totalTime; const progress = (currentTime / totalTime) * 100; if (progressFill) progressFill.style.width = `${progress}%`; if (currentTimeEl) currentTimeEl.textContent = formatTime(currentTime); });
        }
        function openModal(exhibit) {
            if (ttsManager.isSpeaking) ttsManager.stop();
            if (isExhibitAudioPlaying) { ttsManager.stop(); isExhibitAudioPlaying = false; }
            modalTitle.textContent = exhibit.name;
            modalImage.src = exhibit.image;
            modalImage.alt = exhibit.name;
            modalShareLink.href = createExhibitLink(exhibit.id);
            modalSpecs.innerHTML = `<div class="spec-item"><span class="spec-label">Класс:</span><span class="spec-value">${exhibit.class}</span></div>${exhibit.type === 'aircraft' || exhibit.type === 'bomber' ? `<div class="spec-item"><span class="spec-label">Макс. высота:</span><span class="spec-value">${exhibit.maxAltitude}</span></div>` : ''}<div class="spec-item"><span class="spec-label">Макс. скорость:</span><span class="spec-value">${exhibit.maxSpeed}</span></div><div class="spec-item"><span class="spec-label">Дальность:</span><span class="spec-value">${exhibit.range}</span></div>${exhibit.type === 'aircraft' || exhibit.type === 'bomber' ? `<div class="spec-item"><span class="spec-label">Шасси:</span><span class="spec-value">${exhibit.landingGear}</span></div>` : ''}<div class="spec-item"><span class="spec-label">Экипаж:</span><span class="spec-value">${exhibit.crew}</span></div><div class="spec-item"><span class="spec-label">Вооружение:</span><span class="spec-value">${exhibit.armament}</span></div><div class="spec-item"><span class="spec-label">Конструктор:</span><span class="spec-value">${exhibit.designer}</span></div><div class="spec-item"><span class="spec-label">Период:</span><span class="spec-value">${exhibit.period}</span></div>`;
            modalCrew.innerHTML = `<li><strong>Описание:</strong> ${exhibit.description}</li><li><strong>Конструктор:</strong> ${exhibit.designer}</li><li><strong>Известные герои:</strong> ${exhibit.pilots}</li>`;
            modalCulture.innerHTML = `<li><strong>Упоминания в культуре:</strong> ${exhibit.culture}</li>`;
            modal.style.display = 'block';
            document.body.style.overflow = 'hidden';
            history.pushState(null, '', `?id=${exhibit.id}`);
            setTimeout(() => { const audioPlayerHTML = createExhibitAudioPlayer(exhibit.id, exhibit.name); modalCulture.insertAdjacentHTML('beforebegin', audioPlayerHTML); initExhibitAudioPlayer(exhibit.id); }, 100);
        }
        closeModal.addEventListener('click', () => { ttsManager.stop(); isExhibitAudioPlaying = false; modal.style.display = 'none'; document.body.style.overflow = 'auto'; history.pushState(null, '', window.location.pathname); });
        modal.addEventListener('click', (e) => { if (e.target === modal) { ttsManager.stop(); isExhibitAudioPlaying = false; modal.style.display = 'none'; document.body.style.overflow = 'auto'; history.pushState(null, '', window.location.pathname); } });

        // ===================== ОБРАБОТЧИКИ ФИЛЬТРОВ =====================
        document.querySelectorAll('.filter-btn:not(.year-filter)').forEach(button => {
            button.addEventListener('click', function () {
                document.querySelectorAll('.filter-btn:not(.year-filter)').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                currentCountryFilter = this.getAttribute('data-filter');
                applyFilters();
            });
        });
        document.querySelectorAll('.year-filter').forEach(button => {
            button.addEventListener('click', function () {
                document.querySelectorAll('.year-filter').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                currentYearFilter = this.getAttribute('data-year');
                applyFilters();
            });
        });
        document.querySelectorAll('.filter-link').forEach(link => {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                const filter = this.getAttribute('data-filter');
                document.querySelectorAll('.filter-btn:not(.year-filter)').forEach(btn => { btn.classList.remove('active'); if (btn.getAttribute('data-filter') === filter) btn.classList.add('active'); });
                currentCountryFilter = filter;
                applyFilters();
                document.getElementById('gallery').scrollIntoView({ behavior: 'smooth' });
            });
        });

        // ===================== ГЛАВНЫЙ АУДИОГИД =====================
        const audioGuideBtn = document.getElementById('audioGuideBtn');
        const audioControls = document.getElementById('audioControls');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const rewindBtn = document.getElementById('rewindBtn');
        const forwardBtn = document.getElementById('forwardBtn');
        const audioProgressBar = document.getElementById('audioProgressBar');
        const audioProgress = document.getElementById('audioProgress');
        const currentTimeElement = document.getElementById('currentTime');
        const totalTimeElement = document.getElementById('totalTime');
        const mainAudioText = "Добро пожаловать в наш школьный электронный музей 'Великая Отечественная война и СВО'. Наш музей был основан в 2005 году по инициативе учителей истории и группы увлеченных учеников...";
        let isMainAudioPlaying = false, mainAudioProgress = 0, mainAudioInterval = null;
        const mainAudioDuration = 60;
        function formatTime(seconds) { const mins = Math.floor(seconds / 60); const secs = Math.floor(seconds % 60); return `${mins}:${secs < 10 ? '0' : ''}${secs}`; }
        function updateMainAudioProgress() { if (isMainAudioPlaying) { mainAudioProgress += 100 / (mainAudioDuration * 10); if (audioProgress) audioProgress.style.width = `${Math.min(mainAudioProgress, 100)}%`; if (currentTimeElement) currentTimeElement.textContent = formatTime((mainAudioProgress / 100) * mainAudioDuration); if (mainAudioProgress >= 100) stopMainAudio(); } }
        function stopMainAudio() { ttsManager.stop(); isMainAudioPlaying = false; mainAudioProgress = 0; if (mainAudioInterval) clearInterval(mainAudioInterval); audioGuideBtn.classList.remove('playing'); audioGuideBtn.innerHTML = '<i class="fas fa-play"></i> Слушать аудиогид'; playPauseBtn.innerHTML = '<i class="fas fa-play"></i>'; if (audioProgress) audioProgress.style.width = '0%'; if (currentTimeElement) currentTimeElement.textContent = '0:00'; }
        audioGuideBtn.addEventListener('click', () => {
            if (!isMainAudioPlaying) {
                const success = ttsManager.speak(mainAudioText, { rate: 0.9, onStart: () => { isMainAudioPlaying = true; audioGuideBtn.classList.add('playing'); audioGuideBtn.innerHTML = '<i class="fas fa-pause"></i> Аудиогид включен'; playPauseBtn.innerHTML = '<i class="fas fa-pause"></i>'; audioControls.style.display = 'flex'; mainAudioInterval = setInterval(updateMainAudioProgress, 100); }, onEnd: stopMainAudio, onError: () => { alert('Не удалось воспроизвести аудиогид.'); stopMainAudio(); } });
                if (!success) alert('Ваш браузер не поддерживает синтез речи.');
            } else { ttsManager.pause(); isMainAudioPlaying = false; audioGuideBtn.classList.remove('playing'); audioGuideBtn.innerHTML = '<i class="fas fa-play"></i> Слушать аудиогид'; playPauseBtn.innerHTML = '<i class="fas fa-play"></i>'; if (mainAudioInterval) clearInterval(mainAudioInterval); }
        });
        playPauseBtn.addEventListener('click', () => { if (isMainAudioPlaying) { ttsManager.pause(); isMainAudioPlaying = false; playPauseBtn.innerHTML = '<i class="fas fa-play"></i>'; audioGuideBtn.classList.remove('playing'); audioGuideBtn.innerHTML = '<i class="fas fa-play"></i> Слушать аудиогид'; if (mainAudioInterval) clearInterval(mainAudioInterval); } else { ttsManager.resume(); isMainAudioPlaying = true; playPauseBtn.innerHTML = '<i class="fas fa-pause"></i>'; audioGuideBtn.classList.add('playing'); audioGuideBtn.innerHTML = '<i class="fas fa-pause"></i> Аудиогид включен'; mainAudioInterval = setInterval(updateMainAudioProgress, 100); } });
        rewindBtn.addEventListener('click', () => { mainAudioProgress = Math.max(0, mainAudioProgress - (10 / mainAudioDuration) * 100); updateMainAudioProgress(); });
        forwardBtn.addEventListener('click', () => { mainAudioProgress = Math.min(100, mainAudioProgress + (10 / mainAudioDuration) * 100); updateMainAudioProgress(); });
        audioProgressBar.addEventListener('click', (e) => { const rect = audioProgressBar.getBoundingClientRect(); const pos = (e.clientX - rect.left) / rect.width; mainAudioProgress = pos * 100; updateMainAudioProgress(); });
        totalTimeElement.textContent = formatTime(mainAudioDuration);

        // ===================== ПЛАВНАЯ ПРОКРУТКА И ИНИЦИАЛИЗАЦИЯ =====================
        document.querySelectorAll('nav a').forEach(anchor => {
            anchor.addEventListener('click', function (e) { e.preventDefault(); const targetId = this.getAttribute('href'); const targetElement = document.querySelector(targetId); window.scrollTo({ top: targetElement.offsetTop - 80, behavior: 'smooth' }); document.querySelectorAll('nav a').forEach(link => link.classList.remove('active')); this.classList.add('active'); });
        });
        window.addEventListener('scroll', function () { let current = ''; document.querySelectorAll('section').forEach(section => { const sectionTop = section.offsetTop; if (scrollY >= (sectionTop - 100)) current = section.getAttribute('id'); }); document.querySelectorAll('nav a').forEach(link => { link.classList.remove('active'); if (link.getAttribute('href') === `#${current}`) link.classList.add('active'); }); });
        document.addEventListener('DOMContentLoaded', function () {
            createGallery();
            function getUrlParameter(name) { const regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'); const results = regex.exec(window.location.href); return results ? decodeURIComponent(results[2]?.replace(/\+/g, ' ') || '') : null; }
            const exhibitId = getUrlParameter('id');
            if (exhibitId) { const exhibit = exhibitsData.find(item => item.id == exhibitId); if (exhibit) { setTimeout(() => { document.getElementById('gallery').scrollIntoView({ behavior: 'smooth' }); setTimeout(() => openModal(exhibit), 500); }, 100); } }
            document.querySelectorAll('.exhibit-img img').forEach(img => { img.addEventListener('error', function () { const parent = this.parentElement; if (parent) { const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300"><rect width="400" height="300" fill="#8B0000"/><text x="200" y="140" font-family="Arial" font-size="24" fill="white" text-anchor="middle">${this.alt}</text><text x="200" y="180" font-family="Arial" font-size="16" fill="#D4AF37" text-anchor="middle">Изображение временно недоступно</text></svg>`; this.src = 'data:image/svg+xml;base64,' + btoa(svg); } }); });
        });
    </script>
</body>
</html>
